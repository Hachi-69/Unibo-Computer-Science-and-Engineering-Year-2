# Scrivi qui la tua soluzione
x = [1, 2, 3]
y = x.copy()
print(x)
y.append(69)
print(x)
print(y)
print(id(x), id(y))
# x e y qui sono puntano a due celle di memoria diverse, grazie a copy(),
#quindi quando viene modificata una delle due l'altra non cambia





