def num_to_let(num) :
    if num < 0 or num > 5 :
        print(f"il numero deve essere compreso tra 0 e 5: {num}")
    else :
        match num :
            case 0 :
                print("zero")
            case 1 :
                print("uno")
            case 2 :
                print("due")
            case 3 :
                print("tre")
            case 4 :
                print("quattro")
            case 5 :
                print("cinque")

num_to_let(int(input("numero")))

def num_to_let_dict(num):
    dizionario = {
        0 : "zero",
        1 : "uno",
        2 : "due",
        3 : "tre",
        4 : "quattro",
        5 : "cinque"
}
    if num < 0 or num > 5:
        print(f"Il numero deve essere compreso tra 0 e 5: {num}")
    else:
        print(dizionario[num])

num_to_let_dict(int(input("numero")))



