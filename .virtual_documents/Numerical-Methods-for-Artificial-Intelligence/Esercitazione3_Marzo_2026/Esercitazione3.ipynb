import numpy as np

n_array = np.random.normal(0.0, 1.0, 20)

print("Array originale (NON modificato):")
print(n_array)
print("-" * 30)

array_permutato = np.random.permutation(n_array)

print("Array permutato (Copia indipendente):")
print(array_permutato)
print("-" * 30)

print(f"Primi 3 elementi originale: {n_array[:3]}")
print(f"Primi 3 elementi permutato: {array_permutato[:3]}")

