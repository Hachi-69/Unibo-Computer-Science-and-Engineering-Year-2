import numpy as np

A = np.arange(30).reshape(5, 6)
print("Matrice A originale:\n", A)
print(f"Shape di A: {A.shape}\n")
print("-" * 30)

terza_riga = A[2, :]
print("Terza riga:\n", terza_riga)
print(f"Shape: {terza_riga.shape}\n")

seconda_colonna = A[:, 1]
print("seconda colonna:\n", seconda_colonna)
print(f"Shape: {seconda_colonna.shape}\n")

blocco_centrale = A[1:4, 1:5]
print("Blocco centrale (righe 2-4, col 2-5):\n", blocco_centrale)
print(f"Shape: {blocco_centrale.shape}\n")

A_inversa = A[:, ::-1]
print("Matrice con colonne invertite:\n", A_inversa)
print(f"Shape: {A_inversa.shape}")





import numpy as np

